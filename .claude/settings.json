{
  "permissions": {
    "allow": [
      "Skill",
      "Bash(python3 scripts/*)",
      "Bash(python3 -c *)",
      "Bash(pip3 install *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(git pull*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git checkout *)",
      "Bash(git branch*)",
      "Bash(gh workflow run *)",
      "Bash(gh run list *)",
      "Bash(gh run watch*)",
      "Bash(gh run view *)",
      "Read",
      "Write(/spike/**)",
      "Edit(/spike/**)",
      "Edit(/scripts/**)",
      "Write(/scripts/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/spirit-session-start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_USER_PROMPT\" | bash .claude/hooks/spirit-prompt-submit.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-sync.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
