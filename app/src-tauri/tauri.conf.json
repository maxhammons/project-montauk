{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Montauk",
  "version": "0.1.0",
  "identifier": "com.projectmontauk.montauk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5180",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Montauk",
        "width": 1280,
        "height": 740,
        "minWidth": 1024,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
